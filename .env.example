DOMAIN=example.com
ACME_EMAIL=admin@example.com

NUXT_PUBLIC_SITE_URL=https://example.com
NUXT_PUBLIC_API_BASE=/api
NUXT_API_INTERNAL_BASE=http://backend:3001/api

NODE_ENV=production
PORT=3001
FRONTEND_PORT=3000

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dsamotors?schema=public
FEED_PATH=/app/data/feed.csv
AUTO_IMPORT_FEED=true

TOCHKA_API_BASE=https://enter.tochka.com/uapi/acquiring/v1.0
TOCHKA_CREATE_PAYMENT_PATH=/payments-with-receipt
TOCHKA_JWT=
TOCHKA_CLIENT_ID=
TOCHKA_CUSTOMER_CODE=
TOCHKA_MERCHANT_ID=
TOCHKA_CALLBACK_URL=https://example.com/api/tochka/webhook
TOCHKA_SUCCESS_URL=https://example.com/payment/success
TOCHKA_FAIL_URL=https://example.com/payment/fail

RECEIPT_TAX_SYSTEM=OSN
RECEIPT_VAT_TYPE=none
RECEIPT_PAYMENT_METHOD=full_payment
RECEIPT_PAYMENT_OBJECT=commodity
