generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id
  title       String
  description String?
  category    String?
  condition   String?
  address     String?
  brand       String?
  make        String?
  oem         String?
  price       Int
  images      Json
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                String   @id
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  status            String
  email             String?
  phone             String?
  amount            Int
  paymentLinkId     String   @unique
  tochkaOperationId String?
  paymentUrl        String?
  receiptPayload    Json
  productSnapshot   Json
  webhookEvents     WebhookEvent[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WebhookEvent {
  id            String   @id
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id])
  paymentLinkId String?
  source        String
  payload       String
  createdAt     DateTime @default(now())
}
